# === 数据库配置 ===
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_database_name
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# === LLM 配置 (Claude Sonnet 4.5) ===
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=60

# === 嵌入模型配置 (Voyage AI) ===
VOYAGE_API_KEY=your_voyage_api_key_here
VOYAGE_MODEL=voyage-3-large
EMBEDDING_DIMENSION=1024

# === Vector Store 配置 (Pinecone - 可选) ===
# PINECONE_API_KEY=your_pinecone_api_key_here
# PINECONE_ENVIRONMENT=us-west1-gcp
# PINECONE_INDEX_NAME=chatbi-knowledge

# === Redis 缓存配置 ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your_redis_password
CACHE_TTL=3600

# === LangSmith 配置 ===
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=chatbi-production
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# === LangGraph Checkpoint 配置 (PostgreSQL) ===
# CHECKPOINT_DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/checkpoints

# === Agent 配置 ===
MAX_AGENT_ITERATIONS=15
MAX_EXECUTION_TIME=120
ENABLE_STREAMING=true

# === RAG 配置 ===
RETRIEVER_K=20
RETRIEVER_ALPHA=0.5
ENABLE_RERANKING=false
# COHERE_API_KEY=your_cohere_api_key_here

# === 安全配置 ===
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
API_KEY_HEADER=X-API-Key
ENABLE_AUTH=false
JWT_SECRET_KEY=your-secret-key-change-this-in-production
ENCRYPTION_KEY=your-encryption-key-for-sensitive-data
# ⚠️ 生产环境必须设置（防止彩虹表攻击），建议使用随机字符串，如: openssl rand -hex 16
ENCRYPTION_SALT=your-unique-random-salt-change-in-production

# === 监控配置 ===
ENABLE_METRICS=true
METRICS_PORT=9090
LOG_LEVEL=INFO
DEV_MODE=false

# === 重试配置 ===
MAX_RETRIES=3
RETRY_MIN_WAIT=4
RETRY_MAX_WAIT=10
