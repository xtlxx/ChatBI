{
  "brand": {
    "name": "Gemini Clone",
    "description": "Design tokens matching gemini.google.com/app"
  },
  "colors": {
    "primary": {
      "light": "#0B57D0",
      "dark": "#A8C7FA"
    },
    "secondary": {
      "light": "#D3E3FD",
      "dark": "#0842A0"
    },
    "background": {
      "light": "#FFFFFF",
      "dark": "#131314"
    },
    "surface": {
      "light": "#F0F4F9",
      "dark": "#1E1F20"
    },
    "text": {
      "primary": {
        "light": "#1F1F1F",
        "dark": "#E3E3E3"
      },
      "secondary": {
        "light": "#444746",
        "dark": "#C4C7C5"
      }
    }
  },
  "typography": {
    "fontFamily": "Google Sans, Helvetica Neue, sans-serif",
    "weights": {
      "regular": 400,
      "medium": 500
    },
    "sizes": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "base": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem",
      "2xl": "1.5rem",
      "display": "3.5rem"
    }
  },
  "spacing": {
    "grid": "8px",
    "xs": "4px",
    "sm": "8px",
    "md": "16px",
    "lg": "24px",
    "xl": "32px",
    "2xl": "48px"
  },
  "borderRadius": {
    "sm": "8px",
    "md": "12px",
    "lg": "16px",
    "xl": "28px",
    "full": "9999px"
  },
  "shadows": {
    "sm": "0 1px 2px 0 rgb(0 0 0 / 0.05)",
    "md": "0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1)",
    "lg": "0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1)"
  },
  "animation": {
    "duration": {
      "fast": "200ms",
      "normal": "300ms",
      "slow": "500ms"
    },
    "easing": "cubic-bezier(0.4, 0, 0.2, 1)"
  }
}
